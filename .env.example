# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del bot obtenido de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui

# ── Google Gemini ─────────────────────────────────────────────────────────────
# API Key gratuita de: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Modelo a usar (gemini-1.5-flash es gratuito y suficientemente rápido)
GEMINI_MODEL=gemini-1.5-flash

# ── Google Sheets ─────────────────────────────────────────────────────────────
# ID del spreadsheet (se encuentra en la URL: docs.google.com/spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Nombre de la pestaña donde se loguearán los leads (se crea automáticamente)
GOOGLE_SHEET_TAB=Leads

# Credenciales del Service Account de Google Cloud (elige UNA opción):

# Opción A: JSON inline (útil para variables de entorno en servidores)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Opción B: Path a un fichero .json descargado de Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# ── General ───────────────────────────────────────────────────────────────────
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
